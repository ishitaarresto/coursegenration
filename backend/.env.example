# ── Copy this file to .env and fill in your keys ──────────────────────────
# Windows:  copy .env.example .env
# Mac/Linux: cp .env.example .env

# ── LLM (Anthropic Claude) ─────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./lms.db

# ── HeyGen (AI video generation — OPTIONAL) ────────────────────────────────
# Get your key from: https://app.heygen.com -> Settings -> API
# Leave blank to use the free Claude Animated engine instead.
HEYGEN_API_KEY=

# ── Sarvam AI (Indian-language TTS — OPTIONAL) ─────────────────────────────
# Get your key from: https://dashboard.sarvam.ai -> API Keys
# Leave blank to use edge-tts (free, covers 70+ languages).
SARVAM_API_KEY=
